<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Pure Compose app: DeviceDefault base, all real theming done in VitaRemindTheme composable -->
    <style name="Theme.VitaRemind" parent="android:Theme.DeviceDefault.Light.NoActionBar"/>

    <style name="Theme.VitaRemind.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1D9E75</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_vitaremind_splash</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.VitaRemind</item>
    </style>

</resources>
